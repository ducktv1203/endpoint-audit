# Shared
AUDIT_HOST_ID=dev-machine

# Agent -> Server
AUDIT_SERVER_URL=http://127.0.0.1:8000
AUDIT_API_TOKEN=change-me
AUDIT_SPOOL_DIR=.spool
AUDIT_POLL_INTERVAL_SECONDS=2

# Optional file integrity auditing (semicolon-separated paths)
# AUDIT_FILE_HASH_PATHS=C:\Windows\System32\drivers\etc\hosts;C:\path\to\your\app.exe

# Server storage
AUDIT_SERVER_STORAGE_DIR=server_storage

